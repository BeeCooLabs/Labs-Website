---
/**
 * BaseLayout — document shell with full SEO / social / structured-data head.
 * Canonical + absolute OG URLs derive from `site` in astro.config.mjs.
 */
import '@fontsource-variable/inter';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'BeeCooLabs — Privacy-first super apps for everyday life',
  description = 'BeeCooLabs is a privacy-first product lab exploring focused domain super apps for family life, school routines, events, coaching, home planning and community coordination.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-cover.png', Astro.site);

const ogTitle = 'BeeCooLabs — Privacy-first super apps for everyday life';
const ogDescription =
  'A product lab building focused, privacy-conscious digital tools around real-life domains.';

// JSON-LD structured data: Organization + WebSite (no fabricated business details)
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${Astro.site}#organization`,
      name: 'BeeCooLabs',
      url: `${Astro.site}`,
      description:
        'BeeCooLabs is a privacy-first product lab building focused digital tools and domain super apps for everyday life.',
      email: 'hello@beecoolabs.com',
      logo: {
        '@type': 'ImageObject',
        url: new URL('/favicon.svg', Astro.site).toString(),
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${Astro.site}#website`,
      name: 'BeeCooLabs',
      url: `${Astro.site}`,
      description:
        'BeeCooLabs is a privacy-first product lab building focused digital tools and domain super apps for everyday life.',
      publisher: { '@id': `${Astro.site}#organization` },
      inLanguage: 'en',
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />

    <!-- Icons & manifest -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#faf6ec" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BeeCooLabs" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="BeeCooLabs — privacy-first super apps for everyday life"
    />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Sitemap (generated by @astrojs/sitemap at build) -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Flag JS availability early so scroll-reveal styles only apply when JS runs.
         Without JS (or for crawlers), every element stays fully visible. -->
    <script is:inline>
      document.documentElement.classList.add('js-motion');
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <slot />
  </body>
</html>
