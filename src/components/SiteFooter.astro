---
/**
 * SiteFooter — direction 1c: deep olive close with bee mark,
 * quiet link columns and the privacy sign-off line.
 */
import BeeLogo from './BeeLogo.astro';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <p class="footer-wordmark">
        <BeeLogo size={24} variant="dark" />
        <span>BeeCooLabs</span>
      </p>
      <p class="footer-tagline">Privacy-first super apps for everyday life.</p>
      <p class="footer-note">
        Building focused digital tools around real-life domains, with privacy and simplicity at
        the centre.
      </p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <p class="footer-heading">Explore</p>
      <ul role="list">
        <li><a href="#ideas">Ideas</a></li>
        <li><a href="#why">Why BeeCooLabs exists</a></li>
        <li><a href="#roadmap">Roadmap</a></li>
        <li><a href="#share">Share an idea</a></li>
      </ul>
    </nav>

    <div class="footer-contact">
      <p class="footer-heading">Contact</p>
      <a class="footer-mail" href="mailto:hello@beecoolabs.com">hello@beecoolabs.com</a>
    </div>
  </div>

  <div class="container footer-base">
    <p>© {year} BeeCooLabs</p>
    <p>Made with care, not with your data.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink-900);
    color: var(--text-on-deep-soft);
    padding-block: 4rem 2.25rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr 0.8fr;
    gap: clamp(2rem, 5vw, 3.75rem);
  }

  .footer-wordmark {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.02rem;
    font-weight: 650;
    color: var(--cream-50);
    margin: 0 0 1rem;
  }

  .footer-tagline {
    font-size: 0.94rem;
    font-weight: 550;
    color: rgba(250, 246, 236, 0.85);
    margin-bottom: 0.6rem;
  }

  .footer-note {
    font-size: 0.85rem;
    line-height: 1.65;
    color: rgba(250, 246, 236, 0.5);
    max-width: 24rem;
    margin: 0;
  }

  .footer-heading {
    font-size: 0.69rem;
    font-weight: 650;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(250, 246, 236, 0.4);
    margin-bottom: 1rem;
  }

  .footer-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .footer a {
    color: rgba(250, 246, 236, 0.7);
    text-decoration: none;
    font-size: 0.88rem;
    transition: color 0.2s var(--ease-out-soft);
  }

  .footer a:hover {
    color: var(--honey-300);
  }

  .footer-mail {
    color: var(--honey-300) !important;
    font-size: 0.9rem !important;
  }

  .footer-mail:hover {
    color: var(--cream-50) !important;
  }

  .footer-base {
    margin-top: 3.25rem;
    padding-top: 1.4rem;
    border-top: 1px solid rgba(250, 246, 236, 0.1);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-base p {
    margin: 0;
    font-size: 0.75rem;
    color: rgba(250, 246, 236, 0.35);
  }

  @media (max-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.2rem;
    }
  }
</style>
