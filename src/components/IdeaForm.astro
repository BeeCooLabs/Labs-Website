---
/**
 * IdeaForm — direction 1c: minimal white panel, two columns.
 * Left: kicker, title, note and "people are already suggesting" chips.
 * Right: the form (idea title + short message).
 *
 * Client-side only today: nothing is stored or sent anywhere.
 * The submit handler in scripts/motion.ts shows a confirmation message;
 * a future backend swap is a single fetch() call in that handler.
 */
import { suggestionChips } from '../data/sampleIdeas';
---

<div class="idea-panel" id="share" data-reveal>
  <div class="panel-grid">
    <div class="panel-copy">
      <p class="section-kicker">Help shape what comes next</p>
      <h3>Share an idea</h3>
      <p class="panel-note">
        Tell us where everyday coordination still feels harder than it should. No account
        needed — idea capture is not connected yet, this is a preview of how it will work.
      </p>
      <div class="suggestions">
        <p class="suggestions-label">People are already suggesting:</p>
        <ul class="chips" role="list">
          {suggestionChips.map((chip) => <li class="chip">{chip}</li>)}
        </ul>
      </div>
    </div>

    <form class="idea-form" data-idea-form novalidate>
      <div class="field">
        <label for="idea-title">Idea title</label>
        <input
          id="idea-title"
          name="title"
          type="text"
          required
          maxlength="120"
          placeholder="e.g. A calmer way to plan our week"
          autocomplete="off"
        />
      </div>

      <div class="field">
        <label for="idea-message">Short message</label>
        <textarea
          id="idea-message"
          name="message"
          rows="4"
          required
          maxlength="600"
          placeholder="What problem should this solve?"></textarea>
      </div>

      <div class="form-foot">
        <button class="btn btn-dark" type="submit">Share an idea</button>
        <p class="privacy-note">Nothing is stored or tracked today.</p>
      </div>

      <p class="form-status" data-form-status role="status" aria-live="polite"></p>
    </form>
  </div>
</div>

<style>
  .idea-panel {
    margin-top: clamp(3.5rem, 7vw, 5.5rem);
    background: var(--bg-card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-panel);
    padding: clamp(1.75rem, 4vw, 3rem);
    scroll-margin-top: 5.5rem;
  }

  .panel-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(1.75rem, 4vw, 3.5rem);
  }

  .panel-copy h3 {
    font-size: 1.6rem;
    letter-spacing: -0.015em;
    margin-bottom: 0;
  }

  .panel-note {
    margin: 0.9rem 0 0;
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--ink-500);
    max-width: 36ch;
  }

  .suggestions {
    margin-top: 1.7rem;
  }

  .suggestions-label {
    font-size: 0.82rem;
    color: var(--ink-400);
    margin-bottom: 0.65rem;
  }

  .chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .chip {
    border: 1px solid var(--hairline);
    border-radius: var(--radius-pill);
    padding: 0.38rem 0.85rem;
    font-size: 0.79rem;
    color: var(--ink-600);
  }

  /* --- form --- */

  .idea-form {
    display: flex;
    flex-direction: column;
    gap: 1.05rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ink-600);
  }

  input,
  textarea {
    font: inherit;
    font-size: 0.9rem;
    color: var(--ink-900);
    background: var(--cream-50);
    border: 1px solid var(--field-border);
    border-radius: 0.7rem;
    padding: 0.8rem 1rem;
    transition:
      border-color 0.2s var(--ease-out-soft),
      box-shadow 0.2s var(--ease-out-soft);
  }

  textarea {
    resize: vertical;
    min-height: 5.5rem;
  }

  input::placeholder,
  textarea::placeholder {
    color: #a9ad97;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--honey-500);
    box-shadow: 0 0 0 4px rgba(217, 166, 63, 0.16);
  }

  .form-foot {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
  }

  .form-foot .btn {
    padding: 0.8rem 1.75rem;
    font-size: 0.88rem;
  }

  .privacy-note {
    margin: 0;
    font-size: 0.79rem;
    color: var(--ink-400);
  }

  .form-status {
    margin: 0;
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--green-500);
    min-height: 1.4em;
  }

  .form-status.is-error {
    color: var(--clay-600);
  }

  @media (max-width: 820px) {
    .panel-grid {
      grid-template-columns: 1fr;
    }

    .panel-note {
      max-width: 52ch;
    }
  }
</style>
